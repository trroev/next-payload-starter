# ─── App ─────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# Local development (requires Docker: docker compose up -d)
MONGODB_URI=mongodb://localhost:27017/starter

# To point local dev at a hosted Atlas database instead, replace the line above
# with an Atlas connection string of the form:
#
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<cluster>
#
# See `docs/atlas-setup.md` for full provisioning steps.

# ─── Payload CMS ─────────────────────────────────────────────────────────────
PAYLOAD_SECRET=

# Optional: pre-populate the first-run admin creation screen (never commit real values)
PAYLOAD_ADMIN_EMAIL=
PAYLOAD_ADMIN_PASSWORD=
# Set to "true" to pre-fill the form without auto-submitting it
PAYLOAD_ADMIN_PREFILL_ONLY=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Auth (BetterAuth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

