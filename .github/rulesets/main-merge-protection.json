{
  "name": "main: merge protection",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "Generate Types" },
          { "context": "Lint" },
          { "context": "Typecheck" },
          { "context": "Test" },
          { "context": "Coverage" },
          { "context": "E2E (mongodb)" },
          { "context": "E2E (postgres)" }
        ]
      }
    },
    { "type": "required_signatures" },
    { "type": "required_linear_history" },
    { "type": "non_fast_forward" },
    { "type": "deletion" }
  ]
}
